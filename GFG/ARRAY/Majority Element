class Solution {
  public:
    int majorityElement(vector<int>& arr) {
        
        int n = arr.size();
        
        unordered_map<int,int> map;
        
        for(int i=0; i<n; i++){
            map[arr[i]]++;
        }
        
        for(auto &p: map){
           if(p.second > n/2){
              return p.first;
           }
        }
        
        return -1;
    }
};
